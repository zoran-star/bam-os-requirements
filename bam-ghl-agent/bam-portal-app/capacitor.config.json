{
  "appId": "com.byanymeansbusiness.portal",
  "appName": "FullControl",
  "webDir": "www",
  "backgroundColor": "#16140F",
  "server": {
    "url": "https://portal.byanymeansbusiness.com/client-portal.html",
    "errorPath": "offline.html"
  },
  "ios": {
    "contentInset": "never"
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": false,
      "backgroundColor": "#16140F",
      "showSpinner": true,
      "spinnerStyle": "small",
      "iosSpinnerStyle": "small"
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#131416"
    },
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    },
    "Keyboard": {
      "resize": "native",
      "resizeOnFullScreen": true
    }
  }
}
