{
  "crons": [
    {
      "path": "/api/agency-connect?action=mint",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/stripe/reconcile-activations",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/offers/cron-make-sellable",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/schedule/cron-activate-booking",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/clients?action=cron-resend-invites",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/members?action=cron-process-scheduled-pauses",
      "schedule": "15 * * * *"
    },
    {
      "path": "/api/ghl/cron-sync-contacts",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/ghl/cron-sync-pipeline",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/mass-send?action=work",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/action-items?action=cron-due-soon",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/push/cron-weekly",
      "schedule": "0 14 * * 1"
    },
    {
      "path": "/api/marketing?resource=meta-health-cron",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/marketing?resource=content-deadlines-cron",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/clients?action=cron-feedback-digest",
      "schedule": "30 13 * * *"
    },
    {
      "path": "/api/agent-approvals?action=detect",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/agent-confirm?action=detect",
      "schedule": "7,22,37,52 * * * *"
    },
    {
      "path": "/api/agent-closing?action=detect",
      "schedule": "3,18,33,48 * * * *"
    },
    {
      "path": "/api/ghl/cron-post-trial-escalate",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/automations?action=work",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/automations?action=rearm",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/runtime/credits/cron-sweep",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/twilio/migration-watch",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/twilio/usage-sync",
      "schedule": "30 6 * * *"
    },
    {
      "path": "/api/twilio/usage-sync?report=1",
      "schedule": "0 13 1 * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains"
        },
        {
          "key": "Permissions-Policy",
          "value": "geolocation=(), microphone=(), camera=()"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/marketing-tickets",
      "destination": "/api/marketing?resource=tickets"
    },
    {
      "source": "/api/marketing-tickets/(.*)",
      "destination": "/api/marketing?resource=tickets&path=$1"
    },
    {
      "source": "/api/guide-cards",
      "destination": "/api/marketing?resource=guide-cards"
    },
    {
      "source": "/api/guide-cards/(.*)",
      "destination": "/api/marketing?resource=guide-cards&path=$1"
    },
    {
      "source": "/api/asana-import",
      "destination": "/api/asana/tasks?import=1"
    },
    {
      "source": "/api/asana-import/(.*)",
      "destination": "/api/asana/tasks?import=1&path=$1"
    },
    {
      "source": "/api/meta/campaigns",
      "destination": "/api/marketing?resource=meta-campaigns"
    },
    {
      "source": "/api/meta/kpis",
      "destination": "/api/marketing?resource=meta-kpis"
    },
    {
      "source": "/api/meta/adaccounts",
      "destination": "/api/marketing?resource=meta-adaccounts"
    },
    {
      "source": "/api/meta/creatives",
      "destination": "/api/marketing?resource=meta-creatives"
    },
    {
      "source": "/api/auth/staff-meta/start",
      "destination": "/api/marketing?resource=meta-staff-auth&step=prepare"
    },
    {
      "source": "/api/auth/staff-meta/callback",
      "destination": "/api/marketing?resource=meta-staff-auth&step=callback"
    },
    {
      "source": "/api/auth/google/login",
      "destination": "/api/google-oauth?step=login"
    },
    {
      "source": "/api/auth/google/callback",
      "destination": "/api/google-oauth?step=callback"
    },
    {
      "source": "/api/meta/staff-status",
      "destination": "/api/marketing?resource=meta-staff-status"
    },
    {
      "source": "/api/staff",
      "destination": "/api/clients?action=invite-staff"
    },
    {
      "source": "/api/parent/schedule/slots/([^/]+)/book",
      "destination": "/api/parent/schedule/slot-action?slot_id=$1&action=book"
    },
    {
      "source": "/api/parent/schedule/slots/([^/]+)/waitlist",
      "destination": "/api/parent/schedule/slot-action?slot_id=$1&action=waitlist"
    },
    {
      "source": "/api/parent/schedule/slots/(.*)",
      "destination": "/api/parent/schedule/slot?slot_id=$1"
    },
    {
      "source": "/api/parent/reservations/([^/]+)",
      "destination": "/api/parent/reservation?reservation_id=$1"
    },
    {
      "source": "/api/parent/waitlist-entries/([^/]+)",
      "destination": "/api/parent/waitlist-entry?waitlist_id=$1"
    },
    {
      "source": "/api/parent/students/(.*)/entitlements",
      "destination": "/api/parent/student-entitlements?student_id=$1"
    },
    {
      "source": "/api/parent/messages/read",
      "destination": "/api/parent/messages?action=read"
    },
    {
      "source": "/api/parent/messages/unread-count",
      "destination": "/api/parent/messages?action=unread-count"
    },
    {
      "source": "/api/parent/member-management/change-plan",
      "destination": "/api/parent/member-management?action=change-plan"
    },
    {
      "source": "/api/parent/member-management/cancel",
      "destination": "/api/parent/member-management?action=cancel"
    },
    {
      "source": "/api/parent/member-management/pause",
      "destination": "/api/parent/member-management?action=pause"
    },
    {
      "source": "/api/parent/member-management/resume",
      "destination": "/api/parent/member-management?action=resume"
    },
    {
      "source": "/api/parent/billing/payment-method/default",
      "destination": "/api/parent/billing?action=payment-method-default"
    },
    {
      "source": "/api/parent/billing/payment-method",
      "destination": "/api/parent/billing?action=payment-method"
    },
    {
      "source": "/api/parent/billing/summary",
      "destination": "/api/parent/billing?action=summary"
    },
    {
      "source": "/api/client/parent-message-threads/unread-count",
      "destination": "/api/client/parent-message-threads?action=unread-count"
    },
    {
      "source": "/api/client/parent-message-threads/([^/]+)/messages",
      "destination": "/api/client/parent-message-threads?thread_id=$1&action=messages"
    },
    {
      "source": "/api/client/parent-message-threads/([^/]+)/read",
      "destination": "/api/client/parent-message-threads?thread_id=$1&action=read"
    },
    {
      "source": "/api/client/parent-message-threads/([^/]+)",
      "destination": "/api/client/parent-message-threads?thread_id=$1"
    },
    {
      "source": "/api/runtime/offers/([^/]+)/options",
      "destination": "/api/runtime/offers?offer_id=$1"
    },
    {
      "source": "/api/runtime/schedule/templates/([^/]+)",
      "destination": "/api/runtime/schedule/template?template_id=$1"
    },
    {
      "source": "/api/runtime/schedule/slots/([^/]+)/cancel",
      "destination": "/api/runtime/schedule/slot-cancel?slot_id=$1"
    },
    {
      "source": "/api/runtime/trial-bookings/([^/]+)/outcome",
      "destination": "/api/runtime/trial-bookings?trial_booking_id=$1&action=outcome"
    },
    {
      "source": "/api/website/trial-booking/([^/]+)/cancel",
      "destination": "/api/website/trial-booking?trial_booking_id=$1&action=cancel"
    },
    {
      "source": "/api/website/trial-booking/([^/]+)/reschedule",
      "destination": "/api/website/trial-booking?trial_booking_id=$1&action=reschedule"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "ignoreCommand": "[ \"$VERCEL_ENV\" != \"production\" ] || git diff --quiet HEAD^ HEAD -- ."
}
