{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",         "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy",         "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
        { "key": "Permissions-Policy",      "value": "geolocation=(), microphone=(), camera=()" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/marketing-tickets",      "destination": "/api/marketing?resource=tickets" },
    { "source": "/api/marketing-tickets/(.*)", "destination": "/api/marketing?resource=tickets&path=$1" },
    { "source": "/api/guide-cards",            "destination": "/api/marketing?resource=guide-cards" },
    { "source": "/api/guide-cards/(.*)",       "destination": "/api/marketing?resource=guide-cards&path=$1" },
    { "source": "/api/asana-import",           "destination": "/api/asana/tasks?import=1" },
    { "source": "/api/asana-import/(.*)",      "destination": "/api/asana/tasks?import=1&path=$1" },
    { "source": "/api/auth/meta/start",        "destination": "/api/marketing?resource=meta-auth&step=prepare" },
    { "source": "/api/auth/meta/callback",     "destination": "/api/marketing?resource=meta-auth&step=callback" },
    { "source": "/api/meta/campaigns",         "destination": "/api/marketing?resource=meta-campaigns" },
    { "source": "/api/meta/adaccounts",        "destination": "/api/marketing?resource=meta-adaccounts" },
    { "source": "/api/meta/creatives",         "destination": "/api/marketing?resource=meta-creatives" },
    { "source": "/api/auth/staff-meta/start",  "destination": "/api/marketing?resource=meta-staff-auth&step=prepare" },
    { "source": "/api/auth/staff-meta/callback", "destination": "/api/marketing?resource=meta-staff-auth&step=callback" },
    { "source": "/api/meta/staff-status",      "destination": "/api/marketing?resource=meta-staff-status" },
    { "source": "/api/staff",                  "destination": "/api/clients?action=invite-staff" },
    { "source": "/api/(.*)",                   "destination": "/api/$1" },
    { "source": "/(.*)",                       "destination": "/index.html" }
  ]
}
