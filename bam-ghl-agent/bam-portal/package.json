{
  "name": "bam-portal",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "check-types": "tsc --noEmit",
    "lint": "eslint .",
    "lint:parent-api": "eslint api/parent",
    "preview": "vite preview",
    "test:runtime": "bash -lc 'supabase status -o env | grep -E \"^(API_URL|ANON_KEY|SERVICE_ROLE_KEY)=\" > /tmp/bam-runtime.env; source /tmp/bam-runtime.env; VITE_SUPABASE_URL=\"$API_URL\" SUPABASE_URL=\"$API_URL\" RUNTIME_TEST_SUPABASE_URL=\"$API_URL\" RUNTIME_TEST_SUPABASE_ANON_KEY=\"$ANON_KEY\" SUPABASE_SERVICE_ROLE_KEY=\"$SERVICE_ROLE_KEY\" RUNTIME_TEST_SUPABASE_SERVICE_ROLE_KEY=\"$SERVICE_ROLE_KEY\" vitest run api/_runtime api/runtime'"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@sentry/node": "^10.56.0",
    "@sentry/react": "^10.56.0",
    "@supabase/supabase-js": "^2.100.1",
    "jszip": "^3.10.1",
    "pdf-lib": "^1.17.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tsx": "^4.22.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.9"
  }
}
