# Notion Integration
# Get your key at https://www.notion.so/my-integrations
# Then share each page/database with the integration
NOTION_API_KEY=ntn_your_key_here

# Set to "true" to use live Notion data instead of mock data
VITE_NOTION_CONNECTED=true

# GHL Integration
# Create a Private Integration at Settings > Private Integrations
# Scopes needed: Contacts (read), Conversations (read/write), Opportunities (read)
GHL_API_KEY=your_private_integration_token_here
GHL_LOCATION_ID=your_default_location_id_here
VITE_GHL_CONNECTED=true

# Google Sheets Integration (Onboarding Tracker)
# Option A: API key from Google Cloud Console (read-only, easiest)
# Option B: Service account access token (read/write)
GOOGLE_SHEETS_API_KEY=your_google_api_key_here
VITE_SHEETS_CONNECTED=true

# Asana Integration
# Get a Personal Access Token at https://app.asana.com/0/developer-console
ASANA_ACCESS_TOKEN=your_asana_pat_here
VITE_ASANA_CONNECTED=true

# Stripe Integration
# Create a restricted key at https://dashboard.stripe.com/apikeys
# Permissions needed (Read): Customers, Subscriptions, Invoices, Charges, Balance
STRIPE_SECRET_KEY=rk_live_your_key_here
VITE_STRIPE_CONNECTED=true

# Stripe Connect — powers the Member Management "Connect Stripe" button
# 1. Enable Connect:   https://dashboard.stripe.com/connect/get-started
# 2. Get the OAuth client_id: https://dashboard.stripe.com/settings/connect/onboarding-options
# 3. Register the redirect URI in Stripe Connect settings:
#      https://portal.byanymeansbusiness.com/api/stripe/connect
#    (Also add the .vercel.app fallback if previews use OAuth)
STRIPE_CONNECT_CLIENT_ID=ca_your_oauth_client_id_here
# HMAC secret for the OAuth state token. Generate with: openssl rand -hex 32
STRIPE_CONNECT_STATE_SECRET=replace_with_a_random_hex_string
# PLATFORM secret key (the account where Connect is enabled). Used as
# client_secret in the OAuth token exchange + as Bearer for connected-account
# Stripe calls. If unset, Connect falls back to STRIPE_SECRET_KEY — set this
# explicitly when the platform account differs from STRIPE_SECRET_KEY's account.
STRIPE_CONNECT_SECRET_KEY=sk_live_your_platform_secret_key_here

# Stripe webhook signing secret — copy from the webhook endpoint in
# https://dashboard.stripe.com/webhooks  (Connect platform endpoint, listening
# for customer.subscription.created from connected accounts). Used by
# api/stripe/webhook.js to verify Stripe-Signature on the raw request body.
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here

# GHL → portal intake webhook secret. Static shared-secret in the
# X-Webhook-Secret header from GHL Workflow → POST to
# https://portal.byanymeansbusiness.com/api/members/intake. Generate with:
# openssl rand -hex 32
GHL_INTAKE_WEBHOOK_SECRET=replace_with_a_random_hex_string

# GHL inbound-reply webhook secret ("P1 Spine"). Static shared-secret in the
# X-Webhook-Secret header from GHL Workflow ("Customer replied" trigger) →
# POST to https://portal.byanymeansbusiness.com/api/ghl/inbound-webhook.
# Used by api/ghl/inbound-webhook.js to log parent replies for V1.5/V2
# academies. Generate with: openssl rand -hex 32
GHL_WEBHOOK_SECRET=replace_with_a_random_hex_string

# Google Calendar Integration (OAuth)
# Create OAuth Client ID at Google Cloud Console > Credentials
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_CALENDAR_ID=mike@byanymeansbball.com
VITE_CALENDAR_CONNECTED=true

# Supabase (existing)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
